@page "/"
@using CharacterWizard.Client.Services
@inject CharacterWizardState State
@inject RandomCharacterService RandomCharacter
@inject CharacterSessionService SessionService
@inject NavigationManager Navigation

<PageTitle>5e Character Wizard</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">5e Character Wizard</MudText>
<MudText Class="mb-6">
    Build a D&amp;D 5e character using System Reference Document (SRD) mechanics.
    Walk through character meta, ability scores, race, class, background, and review.
</MudText>

<MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.AutoStories"
               OnClick="@StartNewCharacter">
        Start New Character
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Casino"
               Disabled="@_rolling"
               OnClick="@RollRandomCharacter">
        @if (_rolling)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Rolling…</span>
        }
        else
        {
            <span>Roll Random Character</span>
        }
    </MudButton>
    @if (_hasSessions)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.People"
                   Href="characters">
            My Characters
        </MudButton>
    }
</MudStack>

@code {
    private bool _rolling;
    private bool _hasSessions;

    protected override async Task OnInitializedAsync()
    {
        _hasSessions = await SessionService.HasSessionsAsync();
    }

    private void StartNewCharacter()
    {
        State.SessionId = Guid.NewGuid().ToString("N");
        State.Character = new();
        State.ActiveStep = 0;
        Navigation.NavigateTo($"wizard?session={State.SessionId}");
    }

    private async Task RollRandomCharacter()
    {
        _rolling = true;
        var character = await RandomCharacter.GenerateAsync();
        State.SessionId = Guid.NewGuid().ToString("N");
        State.Character = character;
        State.ActiveStep = 7;
        Navigation.NavigateTo($"wizard?session={State.SessionId}");
    }
}


