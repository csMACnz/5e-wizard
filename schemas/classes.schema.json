{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://csMACnz.github.io/5e-wizard/schemas/classes.schema.json",
  "title": "ClassDataFile",
  "description": "Collection of SRD classes with mechanical fields, starting gold, and starting equipment choices.",
  "type": "object",
  "required": ["schemaVersion", "source", "classes"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string" },
    "source": { "type": "string" },
    "classes": {
      "type": "array",
      "items": { "$ref": "#/definitions/Class" }
    }
  },
  "definitions": {
    "Class": {
      "type": "object",
      "required": ["id", "displayName", "hitDie", "primaryAbility", "savingThrows", "proficienciesGranted", "skillChoices", "source"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^class:[a-z0-9-]+$" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
        "description": { "type": "string", "maxLength": 140 },
        "hitDie": { "type": "integer", "enum": [6, 8, 10, 12] },
        "primaryAbility": {
          "type": "array",
          "items": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] }
        },
        "savingThrows": {
          "type": "array",
          "items": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] },
          "minItems": 2,
          "maxItems": 2
        },
        "proficienciesGranted": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "armor": { "type": "array", "items": { "type": "string" } },
            "weapons": { "type": "array", "items": { "type": "string" } },
            "tools": { "type": "array", "items": { "type": "string" } }
          }
        },
        "skillChoices": {
          "type": "object",
          "required": ["count", "options"],
          "additionalProperties": false,
          "properties": {
            "count": { "type": "integer", "minimum": 1 },
            "options": { "type": "array", "items": { "type": "string" } }
          }
        },
        "multiclassPrereqs": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "featuresByLevel": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "spellcasting": { "$ref": "#/definitions/Spellcasting" },
        "subclassLevel": { "type": "integer" },
        "subclassLabel": { "type": "string" },
        "subclassOptions": {
          "type": "array",
          "items": { "$ref": "#/definitions/SubclassOption" }
        },
        "startingEquipmentIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "startingEquipment": { "$ref": "#/definitions/ClassStartingEquipmentInfo" },
        "source": { "type": "string" },
        "srdReference": { "type": "string" }
      }
    },
    "ClassStartingEquipmentInfo": {
      "type": "object",
      "required": ["startingWealthRoll", "fixedItems", "choiceGroups"],
      "additionalProperties": false,
      "properties": {
        "startingWealthRoll": {
          "type": "string",
          "description": "Dice roll formula for the starting wealth alternative (e.g. '2d4*10')."
        },
        "fixedItems": {
          "type": "array",
          "description": "Items granted to all characters of this class with no choice required.",
          "items": { "$ref": "#/definitions/EquipmentGrantItem" }
        },
        "choiceGroups": {
          "type": "array",
          "description": "Mutually exclusive choice groups; the player picks one option per group.",
          "items": { "$ref": "#/definitions/EquipmentChoiceGroup" }
        }
      }
    },
    "EquipmentGrantItem": {
      "type": "object",
      "required": ["itemId", "quantity"],
      "additionalProperties": false,
      "properties": {
        "itemId": { "type": "string", "description": "Equipment item identifier." },
        "quantity": { "type": "integer", "minimum": 1, "description": "Number of this item granted." }
      }
    },
    "EquipmentChoiceGroup": {
      "type": "object",
      "required": ["id", "description", "required", "options"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for this choice group." },
        "description": { "type": "string", "description": "Human-readable description of the choice." },
        "required": { "type": "boolean", "description": "Whether the player must make a selection from this group." },
        "options": {
          "type": "array",
          "items": { "$ref": "#/definitions/EquipmentChoiceOption" },
          "minItems": 1
        }
      }
    },
    "EquipmentChoiceOption": {
      "type": "object",
      "required": ["id", "description", "grantItems", "pickOne"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for this option within its group." },
        "description": { "type": "string", "description": "Human-readable description of this option." },
        "grantItems": {
          "type": "array",
          "description": "Items granted when this option is selected.",
          "items": { "$ref": "#/definitions/EquipmentGrantItem" }
        },
        "pickOne": {
          "type": "boolean",
          "description": "If true, the player must pick exactly one item from grantItems; if false, all items are granted."
        }
      }
    },
    "Spellcasting": {
      "type": "object",
      "required": ["castingType", "spellcastingAbility"],
      "additionalProperties": false,
      "properties": {
        "castingType": {
          "type": "string",
          "enum": ["full", "half", "third", "pact", "none"]
        },
        "spellcastingAbility": {
          "type": "string",
          "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"]
        },
        "prepareSpells": { "type": "boolean" },
        "spellListId": { "type": "string" },
        "cantripsKnownByLevel": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 20,
          "maxItems": 20
        },
        "spellsKnownByLevel": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 20,
          "maxItems": 20
        },
        "ritualCasting": { "type": "boolean" }
      }
    },
    "SubclassOption": {
      "type": "object",
      "required": ["id", "displayName"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^subclass:[a-z0-9-]+:[a-z0-9-]+$" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    }
  }
}
