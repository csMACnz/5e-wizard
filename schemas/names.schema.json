{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://csMACnz.github.io/5e-wizard/schemas/names.schema.json",
  "title": "NamesDataFile",
  "description": "Collections of fantasy character names (full names, given names, and surnames).",
  "type": "object",
  "required": ["schemaVersion", "source", "full", "given", "surname"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "description": "Schema version for this data file." },
    "source": { "type": "string", "description": "Origin or authorship of the name lists." },
    "full": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Complete character names (given name + surname)."
    },
    "given": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Given (first) names."
    },
    "surname": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Family (last) names."
    }
  }
}
